LBase <-rnorm(n*pL, mean = 70, sd = 10**2 )
#0possible treatment effects
TH <- rnorm(n*pH, mean = 2, sd = 1**2)
TL <- rnorm(n*pL, mean = 10, sd = 5**2)
#combining vektors:
Base <- c( HBase, LBase)
Tre <- c(TH,TL)
# if everybody got treatment
oTH <- HBase + TH
oTL <- LBase + TL
#a
eTP <- 0.5
#selcts which students get the treatment
TselEP <- rbinom(n, 1, eTP)
#generating outcome
OEP <- Base + TselEP*Tre
#OLS Estimation
moddelEP <- lm(OEP ~ TselEP)
print("OLS Equal Probability:")
summary(moddelEP)
#ß0 = 68.443
#ß1 = 5.982
#b
#selecting treated
HTP <- 0.3
LTP <- 0.5
TselBH <- rbinom(n*pH, 1, HTP)
TselBL <- rbinom(n*pL,1,LTP)
TselB <- c(TselBH,TselBL)
#generating outcome
OB <- Base + TselB*Tre
#ols:
moddelB <- lm(OB ~ TselB)
print("OLS with unequal variance (b)")
summary(moddelB)
#ß0 =  66.319
#ß1 = 6.903
# variance weighted OLS:
OBH <- HBase + TselBH * TH
OBL <- LBase + TselBL * TL
varH <- HTP*(1-HTP)
varL <- LTP*(1-LTP)
meanTH <- mean(TH)
meanTL <- mean(TL)
ß1tb <- ((pH*varH*meanTH)+(pL*varL*meanTL))/((pH*varH)+(pL*varL))
print(paste("ß1 with variance weihted OLS: " , round(ß1tb,3)))
#ß1T = 6.56
#reapeating 1000 times
OLSV <- numeric(1000)
ATEV <- numeric(1000)
ß1tV <- numeric(1000)
for (i in 1:1000){
set.seed(i*seed)
#base values
HBaseI <-rnorm(n*pH, mean = 70, sd = 10**2 )
LBaseI <-rnorm(n*pL, mean = 70, sd = 10**2 )
#0possible treatment effects
THI <- rnorm(n*pH, mean = 2, sd = 1**2)
TLI <- rnorm(n*pL, mean = 10, sd = 5**2)
#combining vektors:
BaseI <- c( HBaseI, LBaseI)
TreI <- c(THI,TLI)
#ols
TselBHI <- rbinom(n*pH, 1, HTP)
TselBLI <- rbinom(n*pL,1,LTP)
TselBI <- c(TselBH,TselBLI)
#generating outcome
OBI <- BaseI + TselBI*TreI
#ols:
moddelBI <- lm(OBI ~ TselBI)
OLSV[i] <- coef(moddelBI)["TselBI"]
#ATE
ATEV[i] <- mean(TreI)
#variance weighted
OBHI <- HBaseI + TselBHI * THI
OBLI <- LBaseI + TselBLI * TLI
meanTHI <- mean(THI)
meanTLI <- mean(TLI)
ß1tV[i] <- ((pH*varH*meanTHI)+(pL*varL*meanTLI))/((pH*varH)+(pL*varL))
}
set.seed(seed)
OLSmean <- mean(OLSV)
ATEmean <- mean(ATEV)
ß1tMEan <- mean(ß1tV)
cat(
"Average OLS: ", round(OLSmean, 4), "\n",
"Average ATE: ", round(ATEmean, 4), "\n",
"Average variance-weighted estimate: ", round(ß1tMEan, 4), "\n"
)
#Average OLS:  6.9026
#Average ATE:  6.7975
#Average variance-weighted estimate:  7.1256
#no they al differ a bit
moddelG <- lm(OB ~ TselB + OBH)
