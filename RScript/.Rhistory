# Using the built-in IV estimation function in the ivreg package------
# Note: install the package "ivreg" and comment out this line after installing it
install.packages("ivreg")
install.packages("ivreg")
#setup
set.seed(123)
#generating data
N <- 2000
Z <- rbinom(N,1,0.5)
v <- rnorm(N,0,0.1)
D <- 0.05 + 0.6*Z + v
u <- rnorm(N,0,2)
Y <- 2 + 5*D + u
ZMean <- sum(Z)/N
YMean <- sum(Y)/N
DMean <- sum(D)/N
#1
#IV Estimation:
ß1IV <- sum((Z-ZMean)*(Y-YMean))/sum((Z-ZMean)*(D-DMean))
#2SLS Estimation:
gam <- sum((Z-ZMean)*(Y-YMean))/sum((Z-ZMean)**2)
pi <- sum((Z-ZMean)*(D-DMean))/sum((Z-ZMean)**2)
ß12SLS <- gam/pi
Equal <- ß12SLS == ß1IV
cat(paste("Manual IV Estimate (ß1IV):", round(ß1IV, 4), "\nManual 2SLS Estimate (ß12SLS):", round(ß12SLS, 4),"\nEqual: ",Equal))
#2: Wald Estimator
SZe1 <- sum(Z==1)
SZe0 <- sum(Z ==0)
EYZe1 <- sum(Y*Z)/SZe1
EYZe0 <- sum(Y*(-Z+1))/SZe0
EDZe1 <- sum(D*Z)/SZe1
EDZe0 <- sum(D*(-Z+1))/SZe0
ß1Wald <- (EYZe1-EYZe0)/(EDZe1-EDZe0)
print("ß1 Wald Estimator:", ß1Wald)
# estimate IV regression model
iv_model <- ivreg(Y ~ D | Z)
# see results
coef(iv_model)
ß1ivreg <- coef(iv_model)["D"]
AllEqual <- (ß1IV == ß12SLS) &
(ß1IV == ß1Wald) &
(ß1IV == ß1ivreg)
cat("Everything is Equal:", AllEqual)
#setup
set.seed(123)
#generating data
N <- 2000
Z <- rbinom(N,1,0.5)
v <- rnorm(N,0,0.1)
D <- 0.05 + 0.6*Z + v
u <- rnorm(N,0,2)
Y <- 2 + 5*D + u
ZMean <- sum(Z)/N
YMean <- sum(Y)/N
DMean <- sum(D)/N
#1
#IV Estimation:
ß1IV <- sum((Z-ZMean)*(Y-YMean))/sum((Z-ZMean)*(D-DMean))
#2SLS Estimation:
gam <- sum((Z-ZMean)*(Y-YMean))/sum((Z-ZMean)**2)
pi <- sum((Z-ZMean)*(D-DMean))/sum((Z-ZMean)**2)
ß12SLS <- gam/pi
Equal <- ß12SLS == ß1IV
cat(paste("Manual IV Estimate (ß1IV):", round(ß1IV, 4), "\nManual 2SLS Estimate (ß12SLS):", round(ß12SLS, 4),"\nEqual: ",Equal))
#2: Wald Estimator
SZe1 <- sum(Z==1)
SZe0 <- sum(Z ==0)
EYZe1 <- sum(Y*Z)/SZe1
EYZe0 <- sum(Y*(-Z+1))/SZe0
EDZe1 <- sum(D*Z)/SZe1
EDZe0 <- sum(D*(-Z+1))/SZe0
ß1Wald <- (EYZe1-EYZe0)/(EDZe1-EDZe0)
print("ß1 Wald Estimator:", ß1Wald)
# estimate IV regression model
iv_model <- ivreg(Y ~ D | Z)
# see results
coef(iv_model)
ß1ivreg <- as.numeric(coef(iv_model)["D"])
AllEqual <- (ß1IV == ß12SLS) &
(ß1IV == ß1Wald) &
(ß1IV == ß1ivreg)
cat("Everything is Equal:", AllEqual)
set.seed(123)
#generating data
N <- 2000
Z <- rbinom(N,1,0.5)
v <- rnorm(N,0,0.1)
D <- 0.05 + 0.6*Z + v
u <- rnorm(N,0,2)
Y <- 2 + 5*D + u
ZMean <- sum(Z)/N
YMean <- sum(Y)/N
DMean <- sum(D)/N
#1
#IV Estimation:
ß1IV <- sum((Z-ZMean)*(Y-YMean))/sum((Z-ZMean)*(D-DMean))
#2SLS Estimation:
gam <- sum((Z-ZMean)*(Y-YMean))/sum((Z-ZMean)**2)
pi <- sum((Z-ZMean)*(D-DMean))/sum((Z-ZMean)**2)
ß12SLS <- gam/pi
Equal <- ß12SLS == ß1IV
cat(paste("Manual IV Estimate (ß1IV):", round(ß1IV, 4), "\nManual 2SLS Estimate (ß12SLS):", round(ß12SLS, 4),"\nEqual: ",Equal))
#2: Wald Estimator
SZe1 <- sum(Z==1)
SZe0 <- sum(Z ==0)
EYZe1 <- sum(Y*Z)/SZe1
EYZe0 <- sum(Y*(-Z+1))/SZe0
EDZe1 <- sum(D*Z)/SZe1
EDZe0 <- sum(D*(-Z+1))/SZe0
ß1Wald <- (EYZe1-EYZe0)/(EDZe1-EDZe0)
print("ß1 Wald Estimator:", ß1Wald)
# estimate IV regression model
iv_model <- ivreg(Y ~ D | Z)
# see results
coef(iv_model)
ß1ivreg <- as.numeric(coef(iv_model)["D"])
All_Equal <- (round(ß1IV, 10) == round(ß12SLS, 10)) &
(round(ß1IV, 10) == round(ß1Wald, 10)) &
(round(ß1IV, 10) == round(ß1ivreg, 10))
cat("Everything is Equal:", AllEqual)
